{
    "version": 2,
    "framework": null,
    "buildCommand": "yarn install && yarn build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/build/$1" },
        { "src": "/css/(.*)", "dest": "/css/$1" },
        { "src": "/js/(.*)", "dest": "/js/$1" },
        { "src": "/fonts/(.*)", "dest": "/fonts/$1" },
        { "src": "/(favicon\\.ico|robots\\.txt)", "dest": "/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}